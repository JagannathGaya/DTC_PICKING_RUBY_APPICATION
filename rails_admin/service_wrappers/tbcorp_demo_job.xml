<service>
      <id>tbcorp_demo_job</id>
      <name>tbcorp_demo_job</name>
      <description>Thoroughbred Dashboard Demo Job Worker</description>
      <executable>C:\Ruby26-x64\bin\ruby.exe</executable>
      <workingdirectory>C:\rails_projects\tbcorp_demo</workingdirectory>
      <argument>C:\Ruby26-x64\bin\bundle</argument>
      <argument>exec</argument>
      <argument>C:\Ruby26-x64\bin\rake</argument>
      <argument>jobs:work</argument>
      <argument>RAILS_ENV=demo</argument>
      <logpath>C:\rails_projects\tbcorp_demo\log</logpath>
</service>