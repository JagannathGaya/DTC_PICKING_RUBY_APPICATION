<div class="card card-default">
  <div class="card card-heading">
    <div class="row">
      <div class="col-md-6"><%= t('client_location.title', {client: @client.cust_name}) %></div>
      <div class="col-md-6">
        <div class="float-right">
          <%= home_link %>
          <%= list_clients_link %>
          <%= new_client_location_link(@client) %>
        </div>
      </div>
    </div>
  </div>
  <div class="card card-body">
    <div class="table-responsive">
      <table width='100%' id='client_location_list' class='example table-autosort table-autofilter table table-striped table-bordered table-hover table-sm mx-auto w-auto'>
        <thead>
        <tr>
          <th class='table-sortable:alphanumeric'><%= t('client_location.sls_location') %></th>
          <th class='table-sortable:alphanumeric'><%= t('client_location.name') %></th>
          <th></th>
        </tr>
        </thead>
        <tbody>
        <% @client_locations.each do |client_location| %>
          <tr>
            <td><%= edit_client_location_link(@client, client_location) %></td>
            <td><%= client_location.name %></td>
            <td>
              <%= delete_client_location_link(@client, client_location) %>
            </td>
          </tr>
        <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>