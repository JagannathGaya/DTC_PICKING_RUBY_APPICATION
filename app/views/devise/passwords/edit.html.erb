<section id='registration'>
  <div class="card card-default">
    <div class="card-heading"><%= "#{t('user.change_password')}" %></div>
    <div class="card-body">
      <%= bootstrap_form_for(resource, :as => resource_name, :url => password_path(resource_name), :html => {:method => :put}, layout: :horizontal, label_col: "col-sm-3", control_col: "col-sm-9") do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>
        <%= f.hidden_field :reset_password_token %>
        <%= f.password_field :password, label: t('user.new_password'), class: 'required' %>
        <%= f.password_field :password_confirmation, label: t('user.new_confirmation'), class: 'required' %>
        <%= f.submit t('user.change_my_password'), html_options = {class: 'btn btn-primary btn-sm'} %>
      <% end %>
      <%= render "devise/shared/links" %>
    </div>
  </div>
</section>