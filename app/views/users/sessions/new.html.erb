<section id='sign_in'>
  <div class='card card-default' style='max-width: 400px; margin: auto;'>
    <div class="card-heading"><%= "#{t('user.sign_in')}" %></div>
    <div class="card-body">
      <%= bootstrap_form_for resource, :as => resource_name, :url => session_path(resource_name), layout: :horizontal, label_col: "col-4", control_col: "col-8" do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>
        <%= f.select :client_id,
                     Client.using('pg').all.ordered.map {|s| ["#{s.cust_no}:#{s.cust_name}", s.id]},
                     include_blank: t(:select), label: t('user.client'), wrapper: {class: 'form-control-sm'} %>
        <%= f.text_field :empno, label: 'Scan Badge', class: 'uppercase', wrapper: {class: 'form-control-sm'}, autofocus: true %>
        <div class="text-center font-weight-bold">- OR -</div>
        <%= f.email_field :email, autocomplete: 'off', label: {text: t('user.email'), class: 'ays-ignore'}, autofocus: true, required: false, wrapper: {class: 'form-control-sm'} %>
        <%= f.password_field :password, autocomplete: 'off', label: {text: t('user.password'), class: 'ays-ignore'}, required: false, wrapper: {class: 'form-control-sm'} %>

        <%- if devise_mapping.rememberable? %>
          <%= f.form_group do %>
            <%= f.check_box :remember_me, label: t('user.remember_me') %>
          <% end %>
        <% end -%>
        <%= f.submit t('user.sign_in'), html_options = {class: 'btn btn-primary btn-sm'} %>

      <% end %>
      <%= render "devise/shared/links" %>
    </div>
  </div>
</section>